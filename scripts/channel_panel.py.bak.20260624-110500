#!/usr/bin/env python3
"""Mini-channel WhatsApp multi-SDR Zydon.

Painel responsivo com visão por usuário, conversas por chip e resposta de texto.
Lê históricos gerados pelo /root/.hermes/whatsapp-extra/single-extra.js aprimorado.
"""
from __future__ import annotations
import argparse, json, os, secrets, subprocess, time, urllib.error, urllib.parse, urllib.request
from datetime import datetime
from pathlib import Path
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import parse_qs, urlparse

PROJECT = Path('/root/.hermes/zydon-prospeccao')
WA_EXTRA = Path('/root/.hermes/whatsapp-extra')
DATA_DIR = WA_EXTRA / 'channel_data'
USERS_FILE = PROJECT / 'controle' / 'channel_users.json'
MEDIA_PROXY_PREFIX = '/media/'
GROUP_JID = '120363408131718880@g.us'

PORTS = {
    4600: {'label':'Mariana', 'owner':'mariana', 'role':'institucional'},
    4601: {'label':'Sarah 1', 'owner':'sarah', 'role':'sdr'},
    4602: {'label':'Breno 1', 'owner':'breno', 'role':'sdr'},
    4603: {'label':'Lucas Batista', 'owner':'lucas_batista', 'role':'sdr'},
    4604: {'label':'Sarah 2', 'owner':'sarah', 'role':'sdr'},
    4605: {'label':'Breno 2', 'owner':'breno', 'role':'sdr'},
    4606: {'label':'Lucas Resende', 'owner':'lucas_resende', 'role':'institucional'},
    4607: {'label':'Rafael', 'owner':'rafael', 'role':'institucional'},
}
DEFAULT_USERS = {
    'rafael': {'name':'Rafael', 'ports':[4600,4601,4602,4603,4604,4605,4606,4607], 'admin': True},
    'mariana': {'name':'Mariana', 'ports':[4600], 'admin': False},
    'breno': {'name':'Breno', 'ports':[4602,4605], 'admin': False},
    'sarah': {'name':'Sarah', 'ports':[4601,4604], 'admin': False},
    'lucas_batista': {'name':'Lucas Batista', 'ports':[4603], 'admin': False},
    'lucas_resende': {'name':'Lucas Resende', 'ports':[4606], 'admin': False},
}

def ensure_users():
    USERS_FILE.parent.mkdir(parents=True, exist_ok=True)
    if USERS_FILE.exists():
        data = json.loads(USERS_FILE.read_text(encoding='utf-8'))
    else:
        data = {}
    changed=False
    for uid, cfg in DEFAULT_USERS.items():
        if uid not in data:
            data[uid] = {**cfg, 'token': secrets.token_urlsafe(18)}; changed=True
        else:
            for k,v in cfg.items():
                if k not in data[uid]: data[uid][k]=v; changed=True
            if not data[uid].get('token'):
                data[uid]['token']=secrets.token_urlsafe(18); changed=True
    if changed:
        USERS_FILE.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding='utf-8')
        try: os.chmod(USERS_FILE, 0o600)
        except Exception: pass
    return data

USERS = ensure_users()

def user_from_request(path):
    qs=parse_qs(urlparse(path).query)
    uid=(qs.get('u') or qs.get('user') or [''])[0]
    tok=(qs.get('t') or qs.get('token') or [''])[0]
    if not uid or uid not in USERS: return None
    if not tok or not secrets.compare_digest(tok, USERS[uid].get('token','')): return None
    return uid

def read_history(port:int):
    p=DATA_DIR / f'history_{port}.json'
    try:
        data=json.loads(p.read_text(encoding='utf-8')) if p.exists() else []
        return data if isinstance(data, list) else []
    except Exception:
        return []

def load_all(uid):
    allowed=set(USERS[uid]['ports'])
    items=[]
    for port in allowed:
        for m in read_history(int(port)):
            if not isinstance(m, dict): continue
            m=dict(m); m['port']=int(m.get('port') or port); m['portLabel']=PORTS.get(int(port),{}).get('label',str(port));
            items.append(m)
    items.sort(key=lambda x: float(x.get('timestamp') or 0))
    return items

def clean_title_value(v):
    v = str(v or '').strip()
    if not v or v.lower() in {'none','null','sem empresa','sem nome'}:
        return ''
    return v


def short_phone(chat):
    digits=''.join(ch for ch in str(chat or '') if ch.isdigit())
    if len(digits) >= 12:
        return f"+{digits[:2]} {digits[2:4]} {digits[4:-4]}-{digits[-4:]}"
    return str(chat or '')


def source_label(m):
    typ=str(m.get('type') or '')
    if typ == 'cron-sdr-primeiro-contato': return '1º contato SDR'
    if typ == 'cron-mql-texto': return 'Diagnóstico · texto'
    if typ == 'cron-mql-pdf': return 'Diagnóstico · PDF'
    if typ == 'cron-naomql-grupo': return 'Não-MQL interno'
    if not m.get('fromMe'): return 'Resposta recebida'
    return 'WhatsApp'


def conversations(uid):
    conv={}
    is_admin = bool(USERS.get(uid, {}).get('admin'))
    for m in load_all(uid):
        chat=m.get('chat') or ''
        if not chat:
            continue
        # Grupo interno polui a visão de conversas/leads e gera falsas "respostas".
        # O Channel é para conversas individuais; auditoria de grupo fica no dashboard de envios.
        if chat == GROUP_JID or chat.endswith('@g.us'):
            continue
        key=f"{m.get('port')}::{chat}"
        c=conv.setdefault(key, {'id':key,'chat':chat,'title':'','subtitle':'','port':m.get('port'),'portLabel':m.get('portLabel'),'messages':0,'last':None,'lastTime':0,'unread':0,'responses':0,'lastIncoming':None,'lastSource':''})
        c['messages'] += 1
        ts = float(m.get('timestamp') or 0)
        if ts >= float(c.get('lastTime') or 0):
            c['lastTime'] = ts
            c['last'] = m
            c['lastSource'] = source_label(m)
        if not m.get('fromMe'):
            c['unread'] += 1
            c['responses'] += 1
            if ts >= float((c.get('lastIncoming') or {}).get('timestamp') or 0):
                c['lastIncoming'] = m
        # melhor título da conversa inteira: empresa > nome > slug > telefone
        best = clean_title_value(m.get('empresa') or m.get('lead'))
        if best and (not c.get('title') or c.get('title') == short_phone(chat) or c.get('title') == chat):
            c['title'] = best
        name = clean_title_value(m.get('nome'))
        sdr = clean_title_value(m.get('sdr'))
        if name and name.lower() not in str(c.get('title','')).lower():
            c['subtitle'] = name + (f" · {sdr}" if sdr else '')
        elif sdr and not c.get('subtitle'):
            c['subtitle'] = sdr
    out=[]
    for c in conv.values():
        if not c.get('title'):
            c['title'] = short_phone(c.get('chat'))
        if not c.get('subtitle'):
            c['subtitle'] = short_phone(c.get('chat'))
        out.append(c)
    out.sort(key=lambda c: float(c.get('lastTime') or 0), reverse=True)
    return out

def messages_for(uid, conv_id):
    if '::' not in conv_id: return []
    p_s, chat = conv_id.split('::',1)
    try: port=int(p_s)
    except: return []
    if port not in USERS[uid]['ports']: return []
    return [m for m in load_all(uid) if int(m.get('port') or 0)==port and m.get('chat')==chat]

def post_json(url, payload, timeout=20):
    data=json.dumps(payload, ensure_ascii=False).encode('utf-8')
    req=urllib.request.Request(url, data=data, headers={'Content-Type':'application/json'}, method='POST')
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return json.loads(r.read().decode('utf-8') or '{}')

def bridge_status(port):
    try:
        with urllib.request.urlopen(f'http://127.0.0.1:{port}/status', timeout=2) as r:
            return json.loads(r.read().decode())
    except Exception as e: return {'connected':False,'error':str(e)}

