function esc(s){return (s??'').toString().replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m]))}
function dt(ts){try{return new Date((+ts)*1000).toLocaleString('pt-BR')}catch{return ''}}
async function api(path, opts){const r=await fetch(path+(path.includes('?')?'&':'?')+auth, opts); if(!r.ok) throw new Error(await r.text()); return r.json()}
function renderShell(){document.getElementById('root').innerHTML=`<div class="app" id="app"><aside class="sidebar"><div class="top"><div><div class="brand">Zydon Channel</div><div class="small" id="who"></div></div></div><div class="search"><input id="q" placeholder="Buscar conversa"><select id="port"><option value="">Todos os chips</option></select></div><div class="convlist" id="convs"></div></aside><main class="chat"><div class="chathead"><div><button class="ghost mobileBack" onclick="closeChat()">←</button> <b id="chatTitle">Selecione uma conversa</b><div class="small" id="chatSub"></div></div><button class="ghost" onclick="loadAll()">Atualizar</button></div><div class="messages" id="msgs"><div class="small">Escolha uma conversa na esquerda.</div></div><div class="composer"><textarea id="reply" placeholder="Responder por este chip..."></textarea><button onclick="sendReply()">Enviar</button></div></main><aside class="info"><h3>Detalhes</h3><div id="details" class="small">Selecione uma conversa.</div></aside></div>`; document.getElementById('q').oninput=drawConvs; document.getElementById('port').onchange=drawConvs;}
function label(m){if(!m) return ''; if(!m.fromMe) return 'RESPOSTA DO LEAD'; if(m.type==='cron-sdr-primeiro-contato') return '1º CONTATO SDR'; if(m.type==='cron-mql-texto') return 'DIAGNÓSTICO'; if(m.type==='cron-mql-pdf') return 'PDF'; return 'ENVIADA'}
